<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.suven.framework.fileinter.mapper.FileAppStorageConfigMapper">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.suven.framework.fileinter.entity.FileAppStorageConfig" id="fileAppStorageConfigMap">
        <result property="id" column="id"/>
        <result property="appId" column="app_id"/>
        <result property="appName" column="app_name"/>
        <result property="clientId" column="client_id"/>
        <result property="storageConfigId" column="storage_config_id"/>
        <result property="configFiledName" column="config_filed_name"/>
        <result property="configFiledValue" column="config_filed_value"/>
        <result property="createDate" column="create_date"/>
        <result property="modifyDate" column="modify_date"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="deleted" column="deleted"/>
    </resultMap>


    <!-- 批量插入,并返回指定主键字段值; -->
    <insert id="saveBatch" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO
            file_app_storage_config ( app_id, app_name, client_id, storage_config_id, config_filed_name, config_filed_value, create_date, modify_date, tenant_id, deleted )
        VALUES
        <foreach collection="list" item="fileAppStorageConfig" index="index" separator=",">
            (  #{fileAppStorageConfig.appId},  #{fileAppStorageConfig.appName},  #{fileAppStorageConfig.clientId},  #{fileAppStorageConfig.storageConfigId},  #{fileAppStorageConfig.configFiledName},  #{fileAppStorageConfig.configFiledValue},  #{fileAppStorageConfig.createDate},  #{fileAppStorageConfig.modifyDate},  #{fileAppStorageConfig.tenantId},  #{fileAppStorageConfig.deleted} )
        </foreach>
    </insert>


</mapper>